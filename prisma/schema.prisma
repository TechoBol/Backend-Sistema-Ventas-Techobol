generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Location {
  id               Int          @id @default(autoincrement())
  name             String
  type             LocationType
  address          String?
  abbreviation     String?
  saleCounter      Int          @default(0)
  quotationCounter Int          @default(0)
  isVisible        Boolean      @default(true)

  employees   Employee[]
  inventories Inventory[]
  sales       Sale[]
  quotations  Quotation[]

  fromMovements StockMovement[] @relation("FromLocation")
  toMovements   StockMovement[] @relation("ToLocation")

  fromTransfers Transfer[] @relation("FromTransfer")
  toTransfers   Transfer[] @relation("ToTransfer")
}

enum LocationType {
  WAREHOUSE
  BRANCH
}

model Employee {
  id       Int     @id @default(autoincrement())
  name     String
  lastName String
  email    String? @unique
  password String?
  numeral  Int?
  celular  String?
  role     Role    @relation(fields: [roleId], references: [id])
  roleId   Int

  location   Location? @relation(fields: [locationId], references: [id])
  locationId Int?

  isVisible Boolean @default(true)

  sales      Sale[]
  quotations Quotation[]

  requestedTransfers Transfer[] @relation("RequestedBy")
  approvedTransfers  Transfer[] @relation("ApprovedBy")
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  level       Int?
  isVisible   Boolean @default(true)

  employees Employee[]
}

model Line {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  brands      Json?
  isVisible   Boolean @default(true)

  products Product[]
}

model Unit {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  code          String  @unique
  allowDecimals Boolean @default(false)
  isVisible     Boolean @default(true)

  baseProducts Product[]     @relation("BaseUnit")
  productUnits ProductUnit[]
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  code        String  @unique
  isVisible   Boolean @default(true)

  purchasePrice      Float @default(0)
  salePrice          Float @default(0)
  porcentajeGanancia Float @default(50)
  baseUnit           Unit  @relation("BaseUnit", fields: [baseUnitId], references: [id])
  baseUnitId         Int

  line   Line? @relation(fields: [lineId], references: [id])
  lineId Int?

  brandName        String?
  quantityDiscount Float   @default(0)
  bossDiscount     Float   @default(0)

  productUnits      ProductUnit[]
  inventories       Inventory[]
  movements         StockMovement[]
  saleDetails       SaleDetail[]
  quotationDetails  QuotationDetail[]
  transferItems     TransferItem[]
  ImportacionDetail ImportacionDetail[]
}

model ProductUnit {
  id Int @id @default(autoincrement())

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  unit   Unit @relation(fields: [unitId], references: [id])
  unitId Int

  equivalence Float

  purchasePrice Float @default(0)
  salePrice     Float

  isDefault Boolean @default(false)

  saleDetails       SaleDetail[]
  quotationDetails  QuotationDetail[]
  stockMovements    StockMovement[]
  transferItems     TransferItem[]
  ImportacionDetail ImportacionDetail[]

  @@unique([productId, unitId])
}

model Inventory {
  id Int @id @default(autoincrement())

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  location   Location @relation(fields: [locationId], references: [id])
  locationId Int

  quantity    Float @default(0)
  averageCost Float @default(0)

  @@unique([productId, locationId])
}

model StockMovement {
  id Int @id @default(autoincrement())

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  productUnit   ProductUnit? @relation(fields: [productUnitId], references: [id])
  productUnitId Int?

  fromLocation   Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  fromLocationId Int?

  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])
  toLocationId Int?

  quantity             Float
  presentationQuantity Float?

  unitCost Float @default(0)

  type MovementType

  reference String?

  transfer   Transfer? @relation(fields: [transferId], references: [id])
  transferId Int?

  createdAt DateTime @default(now())
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

model Transfer {
  id Int @id @default(autoincrement())

  transferCode String? @unique

  fromLocation   Location? @relation("FromTransfer", fields: [fromLocationId], references: [id])
  fromLocationId Int?

  toLocation   Location? @relation("ToTransfer", fields: [toLocationId], references: [id])
  toLocationId Int?

  status TransferStatus @default(PENDING)

  requestedBy   Employee @relation("RequestedBy", fields: [requestedById], references: [id])
  requestedById Int

  approvedBy   Employee? @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById Int?

  approvedAt DateTime?
  executedAt DateTime?

  rejectionReason String?
  glosa           String?

  items     TransferItem[]
  movements StockMovement[]

  createdAt DateTime @default(now())
}

model TransferItem {
  id Int @id @default(autoincrement())

  transfer   Transfer @relation(fields: [transferId], references: [id])
  transferId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  productUnit   ProductUnit? @relation(fields: [productUnitId], references: [id])
  productUnitId Int?

  presentationQuantity Float?
  quantity             Float
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

model Sale {
  id   Int      @id @default(autoincrement())
  date DateTime @default(now())

  location   Location @relation(fields: [locationId], references: [id])
  locationId Int

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId Int?

  subtotal Float @default(0)
  discount Float @default(0)
  total    Float

  code   String?
  pdfUrl String?

  details SaleDetail[]

  typeSale          String?
  transactionNumber String?

  bankName        String?
  generateInvoice Boolean @default(false)

  paymentMethodChanged Boolean @default(false)
  dateChanged          Boolean @default(false)

  status        SaleStatus @default(COMPLETED)
  cancelReason  String?
  cancelledAt   DateTime?
  cancelledById Int?

  quotation   Quotation? @relation(fields: [quotationId], references: [id])
  quotationId Int?

  customerAddress   CustomerAddress? @relation(fields: [customerAddressId], references: [id])
  customerAddressId Int?

  customerAddressSnapshot   String?
  customerLatitudeSnapshot  Float?
  customerLongitudeSnapshot Float?

  customerNit   CustomerNit? @relation(fields: [customerNitId], references: [id])
  customerNitId Int?

  customerNitSnapshot        String?
  customerNitCompanySnapshot String?
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

model SaleDetail {
  id Int @id @default(autoincrement())

  sale   Sale @relation(fields: [saleId], references: [id])
  saleId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  productUnit   ProductUnit @relation(fields: [productUnitId], references: [id])
  productUnitId Int

  unitName     String
  equivalence  Float
  quantity     Float
  unitPrice    Float
  itemDiscount Float  @default(0)
  subtotal     Float
}

model Quotation {
  id   Int      @id @default(autoincrement())
  code String   @unique
  date DateTime @default(now())

  location   Location @relation(fields: [locationId], references: [id])
  locationId Int

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId Int?

  subtotal Float @default(0)
  discount Float @default(0)
  total    Float

  status    QuotationStatus @default(PENDING)
  notes     String?
  expiresAt DateTime?

  details QuotationDetail[]
  sales   Sale[]

  pdfUrl    String?
  createdAt DateTime @default(now())

  customerNitSnapshot        String?
  customerNitCompanySnapshot String?

  customerAddressSnapshot   String?
  customerLatitudeSnapshot  Float?
  customerLongitudeSnapshot Float?
}

enum QuotationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model QuotationDetail {
  id Int @id @default(autoincrement())

  quotation   Quotation @relation(fields: [quotationId], references: [id])
  quotationId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  productUnit   ProductUnit @relation(fields: [productUnitId], references: [id])
  productUnitId Int

  unitName     String
  equivalence  Float
  quantity     Float
  unitPrice    Float
  itemDiscount Float  @default(0)
  subtotal     Float
}

model Customer {
  id Int @id @default(autoincrement())

  name         String
  nits         CustomerNit[]
  businessName String?
  code         String?       @unique
  phone        String?

  whatsapp              String?
  occupation            String?
  originChannel         String?
  favoritePaymentMethod String?
  reserveAmount         Float    @default(0)
  purchaseFrequencyDays Int?
  createdAt             DateTime @default(now())

  addresses  CustomerAddress[]
  isVisible  Boolean           @default(true)
  sales      Sale[]
  quotations Quotation[]
  activities Activity[]
  notes      Note[]
}

model CustomerAddress {
  id Int @id @default(autoincrement())

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId Int

  label     String?
  address   String
  latitude  Float?
  longitude Float?
  reference String?
  isPrimary Boolean  @default(false)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())

  sales Sale[]
}

model Activity {
  id          Int      @id @default(autoincrement())
  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id])
  type        String
  description String
  createdAt   DateTime @default(now())
}

model Note {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
  content    String
  createdAt  DateTime @default(now())
}

model Importacion {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  supplier  String
  date      DateTime
  total     Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())

  details ImportacionDetail[]
}

model ImportacionDetail {
  id Int @id @default(autoincrement())

  importacion   Importacion @relation(fields: [importacionId], references: [id])
  importacionId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  productUnit   ProductUnit? @relation(fields: [productUnitId], references: [id])
  productUnitId Int?

  quantity Float
  unitCost Float
  subtotal Float
}

model CustomerNit {
  id          Int      @id @default(autoincrement())
  number      String
  companyName String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId Int

  sales Sale[]

  @@unique([customerId, number])
}
